# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your-bot-token-here

# SQLite database path
DB_PATH=data/fantasy.db

# Telegram admin user IDs (comma-separated)
ADMIN_IDS=123456789

# Comma-separated list of group chat IDs (or single GROUP_CHAT_ID for backward compatibility)
GROUP_CHAT_IDS=[-1001234567890]

# F1 Data APIs
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1
OPENF1_BASE_URL=https://api.openf1.org/v1

# Season
SEASON_YEAR=2026

# Game settings (defaults shown)
# TOTAL_BUDGET=100.0
# FREE_TRANSFERS_PER_RACE=2
# EXTRA_TRANSFER_PENALTY=10
# MAX_POLL_ATTEMPTS=40
# POLL_INTERVAL=300
